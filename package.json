{
  "name": "nodzimo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3100",
    "dev:https": "bun run dev --port 3200 --experimental-https",
    "build": "next build --debug",
    "start": "next start",
    "start:demo": "bun run build && bun run start --port 3300",
    "start:cpu-prof": "bun run start --port 3400 --experimental-cpu-prof",
    "type:gen": "next typegen",
    "type:check": "bun run type:gen && tsc --noEmit",
    "analyze": "next experimental-analyze",
    "analyze:output": "bun run analyze --output",
    "info": "next info",
    "lint": "biome check",
    "format": "biome format --write",
    "i18n:check": "i18n-check --source en --locales messages --unused src --format next-intl",
    "deps:install": "bun install",
    "git:pull": "git pull",
    "check": "bun run type:check && bun run lint && bun run i18n:check",
    "verify": "bun run check && bun run build"
  },
  "engines": {
    "node": "25.x",
    "bun": "1.3.13"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "next": "16.2.4",
    "next-intl": "4.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@lingual/i18n-check": "0.9.5",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
