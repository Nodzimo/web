{
  "name": "nodzimo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev-https": "next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "start-cpu-prof": "next start --experimental-cpu-prof",
    "typegen": "next typegen",
    "analyze": "next experimental-analyze",
    "analyze-output": "next experimental-analyze --output",
    "info": "next info",
    "biome:lint": "biome check",
    "biome:format": "biome format --write",
    "i18n:check": "i18n-check --source en --locales messages --unused src --format next-intl",
    "bun:install": "bun install",
    "git:pull": "git pull"
  },
  "engines": {
    "node": "25.x",
    "bun": "1.3.13"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "next": "16.2.4",
    "next-intl": "4.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@lingual/i18n-check": "0.9.5",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "4.2.4",
    "typescript": "5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
