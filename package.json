		"next-intl": "4.13.0",
		"react": "19.2.7",
		"react-dom": "19.2.7"
	},
	"description": "Sefo Nodzimo Web",
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@lingual/i18n-check": "0.9.5",
		"@tailwindcss/postcss": "4.3.0",
		"@types/node": "25.9.1",
		"@types/react": "19.2.16",
		"@types/react-dom": "19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"dependency-cruiser": "17.4.3",
		"fkill-cli": "9.0.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3"
	},
	"engines": {
		"bun": "1.3.x",
		"node": "25.x"
	},
	"funding": [
		{
			"type": "Individual",
			"url": "https://Nodzimo.com/donate"
		},
		{
			"type": "Boosty",
			"url": "https://boosty.to/Nodzimo"
		},
		{
			"type": "Buy Me a Coffee",
			"url": "https://buymeacoffee.com/Nodzimo"
		},
		{
			"type": "Ko-fi",
			"url": "https://ko-fi.com/Nodzimo"
		}
	],
	"homepage": "https://Nodzimo.com",
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"keywords": [
		"Sefo",
		"Nodzimo",
		"Web",
		"Website",
		"Internationalization",
		"Next.js",
		"React",
		"TypeScript",
		"Tailwind",
		"RTL",
		"AI-ready",
		"Agent-ready"
	],
	"license": "MIT",
	"name": "web",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Nodzimo/web.git"
	},
	"scripts": {
		"analyze": "next experimental-analyze",
		"analyze:info": "next info",
		"analyze:output": "bun run analyze --output",
		"biome:migrate": "biome migrate --write",
		"build": "next build --debug",
		"check:deps": "depcruise src",
		"check:deps-graph": "depcruise src --include-only '^src' --output-type dot | dot -Tsvg > dependency-graph.svg",
		"check:fix": "bun run check:lint --write",
		"check:fix-unsafe": "bun run check:fix --unsafe",
		"check:format": "biome format --write",
		"check:lint": "biome check",
		"clean:all": "bun scripts/clean next modules certs",
		"clean:certs": "bun scripts/clean certs",
		"clean:modules": "bun scripts/clean modules",
		"clean:next": "bun scripts/clean next",
		"clean:ports": "fkill :3100 :3150 :3200 :3300 :3400",
		"deps:audit": "bun audit",
		"deps:install": "bun install",
		"deps:outdated": "bun outdated",
		"deps:update": "bun update --interactive",
		"dev": "next dev --port 3100",
		"dev:https": "bun run dev --port 3200 --experimental-https",
		"dev:webpack": "next dev --port 3150 --webpack",
		"git:normalize": "git add --renormalize .",
		"git:pull": "git pull",
		"git:push": "git push",
		"git:reset": "git reset",
		"git:stash": "git stash",
		"git:stash-pop": "git stash pop",
		"git:status": "git status",
		"i18n:check": "i18n-check --source en --locales messages --format next-intl",
		"i18n:unused": "bun run i18n:check --unused src",
		"project:audit": "bun run type:check && bun run check:lint && bun run i18n:check && bun run check:deps && bun run deps:outdated",
		"project:verify": "bun run deps:install && bun run project:audit && bun run build",
		"release:patch": "bun pm version patch",
		"release:push": "git push --follow-tags",
		"release:version": "bun pm version",
		"start": "next start",
		"start:cpu-prof": "bun run start --port 3400 --experimental-cpu-prof",
		"start:preview": "bun run build && bun run start --port 3300",
		"type:check": "bun run type:gen && tsc --noEmit",
		"type:gen": "next typegen",
		"ui-kit:add": "bun install ../ui/ui.tgz",
		"ui-kit:link": "bun link @nodzimo/ui",
		"ui-kit:reinstall": "bun run ui-kit:remove && bun run ui-kit:add",
		"ui-kit:remove": "bun remove @nodzimo/ui"
	},
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	],
	"version": "0.0.3"
}
