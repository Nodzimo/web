{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"linter": {
		"rules": {
			"nursery": {
				"useSortedClasses": { "level": "error", "fix": "safe" }
			},
			"style": {
				"noUnusedTemplateLiteral": "error"
			}
		},
		"domains": {
			"next": "recommended",
			"react": "recommended"
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"quoteStyle": "single",
			"jsxQuoteStyle": "single"
		}
	},
	"html": {
		"formatter": { "enabled": true }
	},
	"css": { "parser": { "tailwindDirectives": true } },
	"json": { "parser": { "allowComments": false } },
	"assist": {
		"actions": {
			"source": {
				"useSortedAttributes": "on",
				"useSortedInterfaceMembers": "on"
			}
		}
	}
}
